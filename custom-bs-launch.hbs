  {{#match page.slug "bs-fabric"}}{{> "launch/fabric"}}{{/match}}
  {{#match page.slug "bs-groundworks"}}{{> "launch/groundworks"}}{{/match}}
  {{#match page.slug "bs-sectors"}}{{> "launch/sectors"}}{{/match}}
  {{#match page.slug "bs-sector-offices"}}{{> "launch/sector-offices"}}{{/match}}
  {{#match page.slug "bs-sector-healthcare"}}{{> "launch/sector-healthcare"}}{{/match}}
  {{#match page.slug "bs-sector-education"}}{{> "launch/sector-education"}}{{/match}}
