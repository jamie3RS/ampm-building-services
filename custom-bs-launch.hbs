{{!-- AMPM Building Services — new "AM→PM" site. One template, slug-routed to a
      page partial (partials/launch/*). Static rebuild of the React design:
      native HTML + hybrid.css, no React/Babel — fast and crawlable. --}}
<!doctype html>
<html lang="en-GB" data-arc="full" data-atmos="animated" style="--d-display:'Big Shoulders Display','Archivo',sans-serif;">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{meta_title}}</title>
  <meta name="description" content="{{meta_description}}" />
  <link rel="canonical" href="{{url absolute="true"}}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@500;600;700;800&family=Archivo:wght@400;500;600;700&family=Archivo+Black&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="{{asset "css/hybrid.css"}}" />
  {{!-- Branded social/link-preview image (WhatsApp, iMessage, Slack, FB, X).
        Placed before ghost_head so this is the primary og:image, overriding
        Ghost's default purple publication-cover placeholder. --}}
  <meta property="og:image" content="{{@site.url}}{{asset "og-card.jpg"}}" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="{{@site.url}}{{asset "og-card.jpg"}}" />
  {{ghost_head}}
  <link rel="icon" type="image/svg+xml" href="{{asset "favicon.svg"}}" />

  {{!-- Structured data: Organization + WebSite site-wide; Service + Breadcrumb per service page --}}
  <script type="application/ld+json">{"@context":"https://schema.org","@type":"Organization","name":"AMPM Building Services","url":"{{@site.url}}","logo":"{{@site.url}}{{asset "favicon.svg"}}","image":"{{@site.url}}{{asset "og-card.jpg"}}","telephone":"+443300430080","areaServed":["London","South East England","Sussex","Surrey","Kent","Hampshire","Berkshire"],"parentOrganization":{"@type":"Organization","name":"AMPM Group","url":"https://www.ampmgroup.co.uk/"},"address":{"@type":"PostalAddress","addressLocality":"Burgess Hill","addressRegion":"West Sussex","addressCountry":"GB"}}</script>
  <script type="application/ld+json">{"@context":"https://schema.org","@type":"WebSite","name":"AMPM Building Services","url":"{{@site.url}}"}</script>
  {{#match page.slug "bs-meph"}}<script type="application/ld+json">{"@context":"https://schema.org","@type":"Service","name":"Mechanical, Electrical & Public Health (MEPH)","serviceType":"MEPH building services","description":"Self-delivered mechanical, electrical and public health packages — HVAC, power, lighting, water services and data — across London and the South East.","provider":{"@type":"Organization","name":"AMPM Building Services"},"areaServed":["London","South East England"],"url":"{{url absolute='true'}}"}</script><script type="application/ld+json">{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"{{@site.url}}/"},{"@type":"ListItem","position":2,"name":"Services","item":"{{@site.url}}/services/"},{"@type":"ListItem","position":3,"name":"MEPH","item":"{{url absolute='true'}}"}]}</script>{{/match}}
  {{#match page.slug "bs-commercial"}}<script type="application/ld+json">{"@context":"https://schema.org","@type":"Service","name":"Commercial Fit-out","serviceType":"Commercial fit-out and refurbishment","description":"Cat A and Cat B commercial fit-out and refurbishment — partitions, joinery, finishes and coordinated M&E — across London and the South East.","provider":{"@type":"Organization","name":"AMPM Building Services"},"areaServed":["London","South East England"],"url":"{{url absolute='true'}}"}</script><script type="application/ld+json">{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"{{@site.url}}/"},{"@type":"ListItem","position":2,"name":"Services","item":"{{@site.url}}/services/"},{"@type":"ListItem","position":3,"name":"Commercial Fit-out","item":"{{url absolute='true'}}"}]}</script>{{/match}}
  {{#match page.slug "bs-fabric"}}<script type="application/ld+json">{"@context":"https://schema.org","@type":"Service","name":"Fabric & Building Envelope","serviceType":"Building fabric and external envelope","description":"Building-envelope and fabric works — cladding, rainscreen, render, roofing, EWI and cladding remediation — across London and the South East.","provider":{"@type":"Organization","name":"AMPM Building Services"},"areaServed":["London","South East England"],"url":"{{url absolute='true'}}"}</script><script type="application/ld+json">{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"{{@site.url}}/"},{"@type":"ListItem","position":2,"name":"Services","item":"{{@site.url}}/services/"},{"@type":"ListItem","position":3,"name":"Fabric","item":"{{url absolute='true'}}"}]}</script>{{/match}}
  {{#match page.slug "bs-groundworks"}}<script type="application/ld+json">{"@context":"https://schema.org","@type":"Service","name":"Landscaping & External Works","serviceType":"Landscaping and external works","description":"Landscaping and external works — hard and soft landscaping, surfacing, boundaries and SuDS drainage — across London and the South East.","provider":{"@type":"Organization","name":"AMPM Building Services"},"areaServed":["London","South East England"],"url":"{{url absolute='true'}}"}</script><script type="application/ld+json">{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"{{@site.url}}/"},{"@type":"ListItem","position":2,"name":"Services","item":"{{@site.url}}/services/"},{"@type":"ListItem","position":3,"name":"Groundworks","item":"{{url absolute='true'}}"}]}</script>{{/match}}
</head>
<body>
  {{#match page.slug "bs-home"}}{{> "launch/home"}}{{/match}}
  {{#match page.slug "bs-services"}}{{> "launch/services"}}{{/match}}
