{{!-- AMPM Building Services — new "AM→PM" site. One template, slug-routed to a
      page partial (partials/launch/*). Static rebuild of the React design:
      native HTML + hybrid.css, no React/Babel — fast and crawlable. --}}
<!doctype html>
<html lang="en-GB" data-arc="full" data-atmos="animated" style="--d-display:'Big Shoulders Display','Archivo',sans-serif;">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{meta_title}}</title>
  <meta name="description" content="{{meta_description}}" />
  <link rel="canonical" href="{{url absolute="true"}}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@500;600;700;800&family=Archivo:wght@400;500;600;700&family=Archivo+Black&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="{{asset "css/hybrid.css"}}" />
  {{!-- Branded social/link-preview image (WhatsApp, iMessage, Slack, FB, X).
        Placed before ghost_head so this is the primary og:image, overriding
        Ghost's default purple publication-cover placeholder. --}}
  <meta property="og:image" content="{{@site.url}}{{asset "og-card.jpg"}}" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="{{@site.url}}{{asset "og-card.jpg"}}" />
  {{ghost_head}}
  <link rel="icon" type="image/svg+xml" href="{{asset "favicon.svg"}}" />
</head>
<body>
  {{#match page.slug "bs-home"}}{{> "launch/home"}}{{/match}}
  {{#match page.slug "bs-services"}}{{> "launch/services"}}{{/match}}
  {{#match page.slug "bs-work"}}{{> "launch/work"}}{{/match}}
  {{#match page.slug "bs-compliance"}}{{> "launch/compliance"}}{{/match}}
  {{#match page.slug "bs-about"}}{{> "launch/about"}}{{/match}}
  {{#match page.slug "bs-contact"}}{{> "launch/contact"}}{{/match}}
  {{#match page.slug "bs-meph"}}{{> "launch/meph"}}{{/match}}
  {{#match page.slug "bs-commercial"}}{{> "launch/commercial"}}{{/match}}
  {{#match page.slug "bs-fabric"}}{{> "launch/fabric"}}{{/match}}
  {{#match page.slug "bs-groundworks"}}{{> "launch/groundworks"}}{{/match}}

  {{!-- Day-arc: the nav disc (--sun-color) sweeps through the four brand
        colours as you scroll a page (orange→green→purple→blue, HSL-blended,
        blue = night); the nav also switches to dark-section mode over dark bands. --}}
  <script>
  (function () {
    var rootEl = document.documentElement;
    var nav = document.querySelector('nav.nav') || document.querySelector('nav');
    // Smooth sweep through the four brand colours (HSL-interpolated so
    // mid-tones stay vivid): orange → green → purple → blue (blue = night).
    var SUN = ['#E87A2C','#E49128','#DFA823','#D6BC23','#CBCA26','#ABC028','#8DB62A','#74AB2B','#5EA12C','#4B982D','#3B8E2E','#2E8E3E','#2E8E5A','#2E8E76','#2E8A8E','#2E6E8E','#2E518F','#2E358F','#442E8F','#612E8F','#7D2E8F','#742E92','#692E94','#5F2E97','#532E9A','#472E9D','#3A2EA0','#2E30A2','#2E3EA5','#2E4CA8','#2E5FAB'];
    var ticking = false;
    function update() {
      ticking = false;
      if (nav) nav.classList.toggle('scrolled', window.scrollY > 10);
      var dark = false;
      document.querySelectorAll('[data-nav-dark]').forEach(function (el) {
        var r = el.getBoundingClientRect();
        if (r.top < 64 && r.bottom > 0) dark = true;
      });
      if (nav) nav.classList.toggle('dark', dark);
      var max = rootEl.scrollHeight - window.innerHeight;
      var p = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;
      rootEl.style.setProperty('--sun-color', SUN[Math.min(SUN.length - 1, Math.floor(p * SUN.length))]);
    }
    function onScroll() { if (!ticking) { ticking = true; requestAnimationFrame(update); } }
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
    setTimeout(update, 300);
  })();
  </script>

  {{!-- Make the whole service-list row on /services/ clickable through to its
        service page (the inner "Explore →" <a> stays the crawlable link). --}}
  <script>
  (function () {
    document.querySelectorAll('.svc-detail.link[id]').forEach(function (row) {
      row.style.cursor = 'pointer';
      row.addEventListener('click', function (e) {
        if (e.target.closest('a')) return;
        window.location.href = '/' + row.id + '/';
      });
    });
  })();
  </script>
  {{ghost_foot}}
</body>
</html>
